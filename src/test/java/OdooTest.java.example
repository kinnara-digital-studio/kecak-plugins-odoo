         SearchFilter[] filters = new SearchFilter[] {
             new SearchFilter("master_category_name", "=", "Raw Material", SearchFilter.OR),
             new SearchFilter("master_category_name", "=", "Finish Good", SearchFilter.AND),
             new SearchFilter("id", "<", 30)
